#!/bin/bash
# info: sync backup metadata with filesystem
# options: [USER] [DRY_RUN]
#
# example: v-sync-backups admin dry-run
#
# This script validates if the backups listed in HestiaCP database actually exist
# on the filesystem (or as valid symlinks). If they are missing, it removes the
# phantom record from HestiaCP to sync the counters.

#----------------------------------------------------------#
#                Variables & Functions                     #
#----------------------------------------------------------#

# Argument definition
user=$1
dry_run=$2

# Includes
source /etc/hestiacp/hestia.conf
source /usr/local/hestia/func/main.sh
source_conf "/usr/local/hestia/conf/hestia.conf"

#----------------------------------------------------------#
#                    Verifications                         #
#----------------------------------------------------------#

if [ ! -z "$user" ] && [ "$user" != "dry-run" ]; then
    check_user "$user"
fi

if [ "$user" = "dry-run" ]; then
    user=""
    dry_run="dry-run"
fi

#----------------------------------------------------------#
#                       Action                             #
#----------------------------------------------------------#

# Define user list
if [ -z "$user" ]; then
    user_list=$(ls $HESTIA/data/users)
else
    user_list="$user"
fi

for user in $user_list; do
    # Read backup config
    if [ ! -f "$HESTIA/data/users/$user/backup.conf" ]; then
        continue
    fi

    # Parse backup config line by line
    while read -r line; do
        # Extract backup filename from config line (BACKUP='filename.tar')
        backup_file=$(echo "$line" | grep "BACKUP=" | cut -d"'" -f2)
        
        if [ -z "$backup_file" ]; then
            continue
        fi

        # Check physical existence
        backup_path="$BACKUP/$backup_file"
        
        # Logic:
        # 1. Check if file exists OR
        # 2. Check if symlink exists and is valid (or broken, but symlink file exists)
        # Note: We check -e (exists) or -L (symlink)
        
        if [ ! -e "$backup_path" ] && [ ! -L "$backup_path" ]; then
            echo "[!] Phantom backup detected for user $user: $backup_file"
            
            if [ "$dry_run" = "dry-run" ]; then
                echo "    [DRY-RUN] Would run: v-delete-user-backup $user $backup_file"
            else
                echo "    [FIX] Removing phantom record..."
                $BIN/v-delete-user-backup "$user" "$backup_file"
                if [ $? -eq 0 ]; then
                    echo "    [OK] Successfully removed."
                else
                    echo "    [ERROR] Failed to remove."
                fi
            fi
        else
            # Optional: Check if symlink is broken?
            if [ -L "$backup_path" ] && [ ! -e "$backup_path" ]; then
                echo "[WARN] Backup $backup_file is a BROKEN symlink. Keeping record, but check target."
            fi
        fi

    done < "$HESTIA/data/users/$user/backup.conf"
    
    # Update stats just in case
    if [ "$dry_run" != "dry-run" ]; then
        $BIN/v-update-user-stats "$user"
    fi
done

exit 0
